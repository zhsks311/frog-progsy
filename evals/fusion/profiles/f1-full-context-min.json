{
  "name": "f1-full-context-min",
  "description": "Full-context mixed-panel variant using codex + anthropic panel members; official F1 acceptance candidate is f1-codex.",
  "targetModel": "frogp/mix",
  "modelMixing": {
    "enabled": true,
    "aliasId": "frogp/mix",
    "mode": "coordinator",
    "combine": "fusion",
    "agents": [
      {
        "provider": "codex",
        "model": "gpt-5.5"
      },
      {
        "provider": "codex",
        "model": "gpt-5.4"
      },
      {
        "provider": "anthropic",
        "model": "claude-sonnet-4-6"
      },
      {
        "provider": "anthropic",
        "model": "claude-opus-4-8"
      }
    ],
    "coordinator": {
      "provider": "anthropic",
      "model": "claude-opus-4-8"
    },
    "fusion": {
      "panel": [
        {
          "provider": "codex",
          "model": "gpt-5.5"
        },
        {
          "provider": "codex",
          "model": "gpt-5.4"
        },
        {
          "provider": "anthropic",
          "model": "claude-sonnet-4-6"
        },
        {
          "provider": "anthropic",
          "model": "claude-opus-4-8"
        }
      ],
      "judge": {
        "provider": "anthropic",
        "model": "claude-opus-4-8"
      },
      "synthesizer": {
        "provider": "anthropic",
        "model": "claude-opus-4-8"
      },
      "contextMode": "full",
      "judgeContextMode": "full"
    },
    "stageTimeoutMs": 45000,
    "panelTimeoutMs": 45000,
    "surfaceStages": true
  }
}
