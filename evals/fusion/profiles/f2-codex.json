{
  "name": "f2-codex",
  "description": "F2 candidate: F1 (full-context panel/judge, strong judge/synth, 60s buffered timeouts) plus opt-in panel synthetic web_search (no-key tier, 1 search per panel member, 4 total). Codex-only panel while the anthropic lane is down.",
  "targetModel": "frogp/mix",
  "modelMixing": {
    "enabled": true,
    "combine": "fusion",
    "agents": [
      { "provider": "codex", "model": "gpt-5.5" },
      { "provider": "codex", "model": "gpt-5.4" },
      { "provider": "codex", "model": "gpt-5.4-mini" }
    ],
    "fusion": {
      "judge": { "provider": "codex", "model": "gpt-5.5" },
      "synthesizer": { "provider": "codex", "model": "gpt-5.5" },
      "contextMode": "full",
      "judgeContextMode": "full",
      "panelWebSearch": {
        "enabled": true,
        "maxSearchesPerPanel": 1,
        "maxTotalSearches": 4,
        "timeoutMs": 10000,
        "tiers": ["no_key"]
      }
    },
    "stageTimeoutMs": 60000,
    "panelTimeoutMs": 60000
  }
}
